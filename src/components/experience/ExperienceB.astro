---
interface Dato {
  puesto: string;
  fecha: string;
  descripcion: string;
  img: string;
  alt: string;
}

const { dato } = Astro.props as { dato: Dato };
---

<div class="flex flex-col items-center justify-center gap-6 md:flex-row md:gap-8">
    <div class="flex w-full justify-center md:w-1/2 md:justify-end">
        <img src={dato.img} alt={dato.alt} class="max-w-full w-40 sm:w-48 dark:rounded-lg dark:bg-white">
    </div>
    <div class="w-full p-0 md:w-1/2 md:p-5">
        <div class="text-center md:text-left">
            <h3 class="text-lg font-semibold mb-2">
                <span class="text-color-rojo dark:text-red-300">{dato.puesto}</span>
            </h3>
            <h3 class="text-lg font-semibold mb-4 text-gray-600 dark:text-slate-300">{dato.fecha}</h3>
            <p class="text-base leading-relaxed mb-4">
                {dato.descripcion}
            </p>
        </div>
    </div>
</div>
