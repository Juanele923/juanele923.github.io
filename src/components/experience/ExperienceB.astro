---
interface Dato {
puesto: string;
fecha: string;
descripcion: string;
img: string;
alt: string;
}

const { dato } = Astro.props as { dato: Dato };
---
<div class="flex flex-row items-center justify-center gap-8">
    <div class="flex w-1/2 justify-end">
        <img src={dato.img} alt={dato.alt} class="max-w-full w-48 ml-auto">
    </div>
    <div class="w-1/2 p-5">
        <div class="text-left">
            <h3 class="text-2xl font-semibold mb-2">
                <span class="text-color-rojo">{dato.puesto}</span>
            </h3>
            <h3 class="text-lg font-semibold mb-1 text-gray-600">{dato.fecha}</h3>
            <p class="text-base leading-relaxed mb-4">
                {dato.descripcion}
            </p>
        </div>
    </div>
</div>