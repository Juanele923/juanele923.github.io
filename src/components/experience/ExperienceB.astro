---
const {puesto, fecha, descripcion, img, alt} = Astro.props;
---
<div class="flex flex-row items-center justify-center gap-8">
    <div class="flex w-1/2 justify-end">
        <img src={img} alt={alt} class="max-w-full w-48 ml-auto">
    </div>
    <div class="w-1/2 p-5">
        <div class="text-left">
            <h3 class="text-2xl font-semibold mb-2">
                <span class="text-color-rojo">{puesto}</span>
            </h3>
            <h3 class="text-lg font-semibold mb-1 text-gray-600">{fecha}</h3>
            <p class="text-base leading-relaxed mb-4">
                {descripcion}
            </p>
        </div>
    </div>
</div>