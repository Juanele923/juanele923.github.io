---
import ExperienceA from "./ExperienceA.astro";
import ExperienceB from "./ExperienceB.astro";

---

<section class="experiencias pb-16 min-h-screen scroll-mt-16" id="experiencia">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-5xl font-extrabold text-center mb-16">Experiencia</h2> 
        <ExperienceA
        puesto="Desarrollador web - Soltel" 
        fecha="Abril 2025 - Junio 2025"
        descripcion="Durante mis 2 meses de prácticas, participé en el desarrollo de software con Java y Spring. Colaboré en la integración de datos y la configuración del entorno, aportando a la resolución de bugs e implementando tareas asignadas."
        img= "../../../public/img/Soltel.png"
        alt= "Soltel-logo"
        />
        <ExperienceB
        puesto="Desarrollador web - Guadaltech" 
        fecha="Enero 2023 - Noviembre 2023"
        descripcion="Como desarrollador web en GuadalTech Soluciones Tecnológicas, me dediqué al desarrollo de sitios web para clientes de diversos sectores, utilizando tecnologías como HTML5, CSS3, JavaScript, Angular, WordPress y Elementor para crear interfaces interactivas y atractivas."
        img= "../../../public/img/Guadaltech.png"
        alt= "GuadalTech"
        />
    </div>
</section>