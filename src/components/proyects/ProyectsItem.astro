---
interface Dato {
title: string;
img: string;
alt: string;
description: string;
}

const { dato } = Astro.props as { dato: Dato };
---
<div class="p-4">
    <h3 class="text-xl font-semibold mb-4 text-center">{dato.title}</h3>
    <div class="relative group rounded-2xl overflow-hidden shadow-lg">
        <img src={dato.img} alt={dato.alt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
        <div class="absolute inset-0 bg-black bg-opacity-70 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center p-6">
            <p class="text-white text-center text-base">
            {dato.description}
            </p>
        </div>
    </div>
</div>