<header id="navbar" class="fixed top-0 left-0 w-full bg-color-nav py-3 shadow-md z-50 transition-colors duration-500">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex justify-between items-center">
      <div class="logo">
        <p class="text-2xl font-extrabold">JL</p>
      </div>
      <nav>
        <ul class="menu flex items-center font-semibold">
          <li class="mx-2">
            <a class="nav-link-underline p-2 text-sm hover:text-color-morado" href="#home">Home</a>
          </li>
          <li class="mx-2">
            <a class="nav-link-underline p-2 text-sm hover:text-color-morado" href="#experiencia">Experiencia</a>
          </li>
          <li class="mx-2">
            <a class="nav-link-underline p-2 text-sm hover:text-color-morado" href="#proyectos">Proyectos</a>
          </li>
          <li class="mx-2">
            <a class="nav-link-underline p-2 text-sm hover:text-color-morado" href="#educacion">Educación</a>
          </li>
          <li class="mx-2">
            <a class="nav-link-underline p-2 text-sm hover:text-color-morado" href="#skills">Skills</a>
          </li>
          <li class="mx-2">
            <a class="nav-link-underline p-2 text-sm hover:text-color-morado" href="#contacto">Contacto</a>
          </li>
          <li class="ml-4">
            <a class="cursor-pointer text-2xl" id="theme-button">
              <i class="fa fa-toggle-on" aria-hidden="true"></i>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>
<style>
			/* Small replacement for the original tailwind @layer styles (keeps underline animation)
				 Uses the same purple used in the original config (#5757e0) */
			.nav-link-underline { position: relative; }
			.nav-link-underline::after {
				content: "";
				display: block;
				height: 2px;
				width: 0;
				margin: 0 auto;
				background-color: #5757e0;
				position: absolute;
				bottom: -1px;
				transition: width 0.5s;
			}
			.nav-link-underline:hover::after { width: 100%; }
		</style>
