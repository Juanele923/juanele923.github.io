---
---

<header id="navbar" class="fixed top-0 left-0 w-full bg-color-nav py-3 shadow-md z-50 transition-colors duration-500 dark:bg-slate-900 dark:shadow-slate-950/60">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between gap-4">
      <div class="logo">
        <p class="text-2xl font-extrabold">JL</p>
      </div>

      <div class="flex items-center gap-4">
        <nav id="mobile-menu" class="absolute left-0 top-full hidden w-full bg-color-nav px-4 pb-4 shadow-md md:static md:block md:w-auto md:bg-transparent md:p-0 md:shadow-none dark:bg-slate-900 md:dark:bg-transparent" aria-label="Navegación principal">
          <ul class="menu flex flex-col items-center gap-2 font-semibold md:flex-row md:justify-end">
            <li><a class="nav-link-underline block p-2 text-sm hover:text-color-morado dark:hover:text-violet-300" href="#home">Home</a></li>
            <li><a class="nav-link-underline block p-2 text-sm hover:text-color-morado dark:hover:text-violet-300" href="#experiencia">Experiencia</a></li>
            <li><a class="nav-link-underline block p-2 text-sm hover:text-color-morado dark:hover:text-violet-300" href="#proyectos">Proyectos</a></li>
            <li><a class="nav-link-underline block p-2 text-sm hover:text-color-morado dark:hover:text-violet-300" href="#educacion">Educación</a></li>
            <li><a class="nav-link-underline block p-2 text-sm hover:text-color-morado dark:hover:text-violet-300" href="#skills">Skills</a></li>
            <li><a class="nav-link-underline block p-2 text-sm hover:text-color-morado dark:hover:text-violet-300" href="#contacto">Contacto</a></li>
          </ul>
        </nav>

        <button class="cursor-pointer text-2xl leading-none transition-colors hover:text-color-morado dark:hover:text-violet-300" id="theme-button" type="button" aria-label="Activar modo oscuro" onclick="window.toggleTheme && window.toggleTheme()">
          <i class="fa fa-toggle-on" aria-hidden="true"></i>
        </button>

        <button id="menu-button" class="text-2xl leading-none transition-colors hover:text-color-morado md:hidden dark:hover:text-violet-300" type="button" aria-label="Abrir menú" aria-controls="mobile-menu" aria-expanded="false" onclick="window.toggleMobileMenu && window.toggleMobileMenu()">
          <i class="fa fa-bars" aria-hidden="true"></i>
        </button>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const setThemeState = (isDark, shouldSave = true) => {
    const themeButton = document.querySelector('#theme-button');
    const themeIcon = themeButton?.querySelector('i');

    document.documentElement.classList.toggle('dark', isDark);
    document.body?.classList.toggle('dark', isDark);
    themeIcon?.classList.toggle('fa-toggle-on', !isDark);
    themeIcon?.classList.toggle('fa-toggle-off', isDark);
    themeButton?.setAttribute('aria-label', isDark ? 'Activar modo claro' : 'Activar modo oscuro');

    if (shouldSave) {
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (_) {
        // The theme still toggles even if localStorage is unavailable.
      }
    }
  };

  window.toggleTheme = () => {
    setThemeState(!document.documentElement.classList.contains('dark'));
  };

  const setMobileMenuState = (isOpen) => {
    const menu = document.querySelector('#mobile-menu');
    const menuButton = document.querySelector('#menu-button');
    const menuIcon = menuButton?.querySelector('i');

    menu?.classList.toggle('hidden', !isOpen);
    menuButton?.setAttribute('aria-expanded', String(isOpen));
    menuButton?.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
    menuIcon?.classList.toggle('fa-bars', !isOpen);
    menuIcon?.classList.toggle('fa-times', isOpen);
  };

  window.toggleMobileMenu = () => {
    const menu = document.querySelector('#mobile-menu');
    setMobileMenuState(menu?.classList.contains('hidden') ?? true);
  };

  const initHeaderControls = () => {
    const themeButton = document.querySelector('#theme-button');
    const menu = document.querySelector('#mobile-menu');

    if (!themeButton || themeButton.dataset.headerReady === 'true') return;

    setThemeState(document.documentElement.classList.contains('dark') || document.body?.classList.contains('dark'), false);
    setMobileMenuState(false);
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setMobileMenuState(false));
    });
    themeButton.dataset.headerReady = 'true';
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeaderControls, { once: true });
  } else {
    initHeaderControls();
  }

  document.addEventListener('astro:page-load', initHeaderControls);
</script>

<style>
  .nav-link-underline { position: relative; }
  .nav-link-underline::after {
    content: "";
    display: block;
    height: 2px;
    width: 0;
    margin: 0 auto;
    background-color: #5757e0;
    position: absolute;
    bottom: -1px;
    transition: width 0.5s;
  }
  .nav-link-underline:hover::after { width: 100%; }
</style>
