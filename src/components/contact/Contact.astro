                    </p>
                    <ul class="flex justify-center space-x-4 text-2xl md:justify-start">
                        <li>
                            <a href="https://www.linkedin.com/in/juan-l%C3%B3pez-ortiz/" class="hover:text-color-morado transition-colors dark:hover:text-violet-300">
                                <i class="fa fa-linkedin" aria-hidden="true"></i>
                            </a>
                        </li>
                        <li>
                            <a href="https://github.com/juanele923" target="_blank" class="hover:text-color-morado transition-colors dark:hover:text-violet-300">
                                <i class="fa fa-github-square" aria-hidden="true"></i>
                            </a>
                        </li>
                        <li>
                            <a href="mailto:juanele92@gmail.com" class="hover:text-color-morado transition-colors dark:hover:text-violet-300">
                                <i class="fa fa-envelope" aria-hidden="true"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
