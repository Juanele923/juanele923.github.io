<section class="contactme py-16 min-h-screen scroll-mt-14 md:scroll-mt-20" id="contacto">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl font-extrabold text-center mb-10 sm:text-5xl sm:mb-16">Contacto</h2>
        <div class="flex flex-col items-center justify-center gap-8 md:flex-row">
            <div class="w-full order-1 max-w-sm md:w-1/2 md:max-w-none">
                <img src="/img/Contacto.png" alt="Imagen de contacto" class="w-full dark:brightness-90">
            </div>
            <div class="w-full p-0 order-2 md:w-1/2 md:p-5">
